@startuml PrefixSharingArchitecture

title Prefix Sharing 完整架构图 (Current)

' ==================== Dependency 层 ====================
package "dependency/ (外部框架 - 侵入式修改)" as DependencyLayer #E3F2FD {

    ' ---- verl_v070 ----
    package "verl_v070/" as VerlPkg #BBDEFB {
        class "MegatronPPOActor" as MegatronPPOActor #90CAF9 {
            +forward_step()
            .. 负责单次 micro-batch 前向传播，调用 prefix sharing 准备和恢复 ..
            __关键修改 (所在函数)__
            +__init__(): Line 61-70 加入try/except
            .. 为了导入 prefix-sharing 模块，模块缺失时自动回退原始行为，不阻塞正常使用 ..
            +forward_step(): Line 585-593 插入 build_prefix_sharing_micro_batch()
            .. 在micro-batch内部，做前缀匹配、batch裁剪、生成 PrefixRuntimeState ..
            +forward_step(): Line 631-632 判断是否启用fused kernels
            ..当前不兼容融合算子，需要跑异常 ..
            +forward_step(): Line 680-681 插入 prefix_sharing_runtime_context()
            .. 为核心的forward_fn建立PrefixSharingRuntimeContext，传递PrefixSharingPlan、PrefixKVStore、LastRestoreSlots等 ..
            +forward_step()/logits_processor(): Line 669-675 插入 restore_suffix_first_log_probs_from_prefix()
            .. 用于logits_processor中 恢复 suffix第一个token的 logprob ..
        }
    }
    
    ' ---- megatron_v0150 ----
    package "megatron_v0150/" as MegatronPkg #C8E6C9 {
        class "SelfAttention" as SelfAttention #A5D6A7 {
            +forward()
            .. 自注意力前向传播，QKV 计算后插入 prefix sharing hook ..
            __关键修改 (所在函数)__
            +forward()
            .. try/except 导入并调用 maybe_run_prefix_sharing_attention()，模块缺失时自动回退 ..
            +forward()
            .. 若 hook 成功，直接返回结果拦截原始逻辑 ..
            +forward()
            .. 原始 RoPE/Attention 逻辑，hook 失败时继续执行 ..
        }
    }
}

' ==================== Integration 层 ====================
package "prefix-sharing/integrations/ (框架适配层)" as IntegrationLayer #FFF3E0 {
    
    class "verl_mcore.py" as VerlMcore #FFCC80 {
        +VerlMCoreBatchAdapter
        .. 框架轻量适配器，将 verl micro-batch 转为 prefix-sharing metadata 和裁剪后的 inputs/labels/masks ..
        +VerlMCoreIntegration
        .. 安装 Megatron attention patch 的集成入口 ..
        +build_prefix_sharing_micro_batch()
        .. 前缀检测入口：配置验证 → 执行前缀复用计划（plan） → batch 裁剪 → 构建 PrefixSharingRuntimeState ..
        +restore_suffix_first_log_probs_from_prefix()
        .. 恢复 reuser 的 suffix-first logprob，从 context 读取 restore_slots 并重新计算 ..
        +PrefixSharingConfig.from_raw(actor_config.prefix_sharing_config)
        .. 从 verl actor 配置读取 prefix_sharing_config，语义解析和环境变量覆盖统一交给 PrefixSharingConfig ..
        +enable_prefix_sharing()
        .. 启用 prefix sharing 集成入口 ..
        +prefix_sharing_enabled()
        .. 上下文管理器包装 enable_prefix_sharing ..
    }
    
    class "verl_mcore.py\nPrefixSharingRuntimeState" as RuntimeState #FFCC80 {
        +prefix_sharing_plan: PrefixSharingPlan
        .. 执行计划，包含 reuse_specs、裁剪范围、restore slots 等 ..
        +backend: Any
        .. attention backend 实例，如 TorchReferenceBackend ..
        +kept_position_ids: Any
        .. 保留的原始位置编码，用于 RoPE 计算 ..
        +packed_cu_seqlens: list[int]
        .. 当前 forward 的 packed THD row offset，用于 context 派生恢复索引 ..
    }
    
    class "context.py\nPackedPrefixLastRestoreIndex" as PackedRestoreIndex #FFCC80 {
        +reuse_idx_in_batch: int
        +provider_idx_in_batch: int
        +provider_1d_pos: int
        +reuse_1d_pos: int
    }
    
    class "verl_mcore.py\nVerlMCorePrefixSharingBatch" as VerlBatch #FFCC80 {
        +prefix_sharing_plan: PrefixSharingPlan
        +input_ids: TrimmedBatch[int]
        +labels: TrimmedBatch[Any] | None
        +loss_masks: TrimmedBatch[Any] | None
    }
    
    class "megatron_runtime.py" as MegatronRuntime #FFCC80 {
        +maybe_run_prefix_sharing_attention()
        .. Attention 拦截执行核心：检查 context → 应用 RoPE → build_kv → attention → 返回结果 ..
        +_apply_positioned_rope()
        .. 应用保留的原始位置编码，处理非连续位置并利用 RoPE 线性特性外推扩展 ..
    }
    
    class "context.py" as Context #FFCC80 {
        +PrefixSharingRuntimeContext()
        .. 运行时上下文数据类，存储执行计划、KV Store、backend、位置编码和 restore slots ..
        +prefix_sharing_runtime_context()
        .. 上下文管理器：创建 RuntimeContext → 设置 ContextVar → yield → 清理 store ..
        +current_prefix_sharing_context()
        .. 获取当前线程的 prefix sharing 上下文，供 Megatron attention hook 使用 ..
    }
    
    class "megatron_attention.py" as MegatronAttentionInt #FFCC80 {
        +MegatronAttentionIntegration()
        .. Megatron attention 集成入口，封装 patch 安装 ..
        +install()
        .. 校验配置并返回 PatchHandle，用于安装 attention hook ..
    }
    
    class "patch_manager.py" as PatchManager #FFCC80 {
        +PatchHandle
        .. 可回滚的 patch 句柄，支持 disable() 恢复原始属性 ..
        +PatchManager
        .. 安装属性 patch，若任一步骤失败则回滚 ..
    }
}

' ==================== Core 层 ====================
package "prefix-sharing/core/ (核心语义层)" as CoreLayer #F3E5F5 {
    
    class "config.py\nPrefixSharingConfig" as Config #CE93D8 {
        +enable_prefix_sharing: bool
        +detector: str = "trie"
        +backend: str = "torch_ref"
        +min_prefix_len: int
        +min_group_size: int
        +boundary_strategy: str = "prefix_last_restore"
        +supported_pp_size: int = 1
        +supported_cp_size: int = 1
        +supported_rope_fusion: bool = False
        +supported_fused_qkv_rope: bool = False
        +validate_precision: bool = False
        +integrate_mode: str = "verl_megatron_actor"
        +model_type: str = "text_only_causal_lm"
        +validate()
        .. 配置验证，检查 phase 1 约束与框架兼容性 ..
    }
    
    class "prefix_detector.py\nPrefixDetector (ABC)" as Detector #CE93D8 {
        +{abstract} detect()
        .. 前缀检测抽象接口，输入 batch token IDs，输出 PrefixDetectionResult ..
    }
    
    class "prefix_detector.py\nTriePrefixDetector" as TrieDetector #CE93D8 {
        +detect()
        .. Trie 树检测入口，在线匹配最长公共前缀并输出复用关系 ..
    }
    
    class "prefix_detector.py\nPrefixDetectionResult" as DetectionResult #CE93D8 {
        +batch_size: int
        +reuse_specs: tuple[PrefixReuseSpec, ...]
        +groups: tuple[PrefixGroup, ...]
        +group_ids: tuple[int, ...]
        +provider_index: tuple[int, ...]
        +prefix_lens: tuple[int, ...]
        +is_provider: tuple[bool, ...]
    }
    
    class "prefix_detector.py\nPrefixGroup" as PrefixGroup #CE93D8 {
        +group_id: int
        +member_indices: tuple[int, ...]
        +prefix_len: int
        +provider_index: int
    }
    
    class "planner.py\nPrefixSharingPlanner" as Planner #CE93D8 {
        +config: PrefixSharingConfig
        +detector: TriePrefixDetector | None
        +plan()
        .. 执行规划入口，detect → plan_from_detection，生成 PrefixSharingPlan ..
        +plan_from_detection()
        .. 基于已有 PrefixDetectionResult 生成执行计划 ..
    }
    
    class "planner.py\nPrefixLastRestoreSpec" as RestoreSpec #CE93D8 {
        +reuse_idx_in_batch: int
        +provider_idx_in_batch: int
        +provider_prefix_last_pos: int
        +reuse_first_suffix_label_pos: int
        +output_slot: int
        +group_id: int
    }
    
    class "planner.py\nPrefixSharingPlan" as Plan #CE93D8 {
        +forward_id: int
        +micro_batch_id: int
        +batch_size: int
        +original_lengths: list[int]
        +reuse_specs: list[PrefixReuseSpec]
        +group_ids: list[int]
        +is_provider: list[bool]
        +provider_index: list[int]
        +prefix_lens: list[int]
        +suffix_lens: list[int]
        +kept_lengths_q: list[int]
        +expanded_lengths_kv: list[int]
        +cu_seqlens_q: list[int]
        +cu_seqlens_kv: list[int]
        +max_seqlen_q: int
        +max_seqlen_kv: int
        +q_position_offsets: list[int]
        +kv_position_offsets: list[int]
        +input_keep_ranges: list[Range]
        +label_keep_ranges: list[Range]
        +loss_mask_keep_ranges: list[Range]
        +prefix_last_restore: list[PrefixLastRestoreSpec]
        +has_sharing: property
        +is_reuser()
        +q_range_for_batch()
        +kv_range_for_batch()
        +restore_for_reuse()
    }
    
    class "prefix_detector.py\nPrefixReuseSpec" as ReuseSpec #CE93D8 {
        +reuse_idx_in_batch: int
        +provider_idx_in_batch: int
        +prefix_len: int
    }
    
    Plan ..> ReuseSpec : reuse_specs 引用
    Plan ..> RestoreSpec : prefix_last_restore 引用
    
    class "batch_trim.py\nTrimmedBatch" as TrimmedBatch #CE93D8 {
        +rows: list[list[T]]
        +flattened: list[T]
        +cu_seqlens: list[int]
    }
    
    class "batch_trim.py" as BatchTrim #CE93D8 {
        +trim_batch()
        .. 通用裁剪函数，返回 TrimmedBatch ..
        +trim_inputs()
        .. 裁剪 input_ids，保留每个样本的 suffix ..
        +trim_labels()
        .. 裁剪 labels，对齐裁剪后的 input_ids ..
        +trim_loss_masks()
        .. 裁剪 loss mask ..
    }
    
    class "logprob.py" as Logprob #CE93D8 {
        +restore_prefix_last_logprobs()
        .. 组装包含 prefix-last 恢复语义的 response logprobs ..
        +build_provider_prefix_last_values()
        .. 从 provider 行收集 prefix-last 值 ..
        +compute_token_logprobs_from_logits()
        .. 从 logits 计算 token logprobs (需要 PyTorch) ..
        +restore_prefix_last_logprobs_tensor()
        .. 将恢复的 logprobs 插入填充的响应张量 ..
        +gather_provider_prefix_last_logits()
        .. 收集每个 reuse 样本的 provider prefix-last logits ..
